{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Flint",
  "theme": "mint",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#F97316",
    "light": "#FB923C",
    "dark": "#EA580C"
  },
  "fonts": {
    "body": {
      "family": "Inter"
    },
    "heading": {
      "family": "Inter"
    }
  },
  "topbar": {
    "links": [
      {
        "name": "GitHub",
        "url": "https://github.com/jverre/flint",
        "icon": "github"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Get started",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction", "quickstart"]
          }
        ]
      },
      {
        "tab": "SDK",
        "groups": [
          {
            "group": "Python SDK",
            "pages": [
              "sdk/sandbox",
              "sdk/agents",
              "sdk/commands",
              "sdk/pty",
              "sdk/templates"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Commands",
            "pages": [
              "cli/overview",
              "cli/start",
              "cli/backends",
              "cli/agents",
              "cli/app",
              "cli/list",
              "cli/stop"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "REST API",
            "pages": [
              "api-reference/overview",
              "api-reference/health",
              "api-reference/vms",
              "api-reference/exec",
              "api-reference/processes",
              "api-reference/files",
              "api-reference/templates",
              "api-reference/terminal"
            ]
          }
        ]
      },
      {
        "tab": "Architecture",
        "groups": [
          {
            "group": "How it works",
            "pages": [
              "architecture/overview",
              "architecture/backends",
              "architecture/golden-snapshots",
              "architecture/networking",
              "architecture/guest-agent"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/jverre/flint",
      "x": "https://x.com/jverre"
    }
  }
}
